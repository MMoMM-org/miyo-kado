# Claude runtime state
.claude/projects/
.claude/shell-snapshots/
.claude/auto-memory/
.claude/plans/
.claude/cache/
.claude/backups/
.claude/file-history/
.claude/history.jsonl
.claude/mcp-needs-auth-cache.json
.claude/*.log
