{
  "env": {
    "ENABLE_LSP_TOOL": "1"
  },
  "permissions": {
    "allow": [],
    "deny": []
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/coder/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/coder/.claude/hooks/dev-notify-bridge.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/local/bin/claude-scripts/security-precheck.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/local/bin/claude-scripts/security-scan.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/home/coder/.claude/the-custom-startup-statusline-enhanced.sh"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "tcs-helper@the-custom-startup": true,
    "tcs-team@the-custom-startup": true,
    "tcs-workflow@the-custom-startup": true,
    "tcs-patterns@the-custom-startup": true
  },
  "extraKnownMarketplaces": {
    "the-custom-startup": {
      "source": {
        "source": "github",
        "repo": "MMoMM-org/the-custom-startup"
      }
    }
  },
  "plansDirectory": "./.claude/plans",
  "autoUpdates": false,
  "telemetry": false,
  "skipDangerousModePermissionPrompt": true
}
