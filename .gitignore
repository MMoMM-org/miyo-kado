# vscode
.vscode 

# Intellij
*.iml
.idea

# npm
node_modules

# Don't include the compiled main.js file in the repo.
# They should be uploaded to GitHub releases instead.
main.js

# Build output (release assets)
build/

# Test coverage
coverage/

# Exclude sourcemaps
*.map

# obsidian
data.json

# Test vault build artifacts (copied by npm run build, not symlinks)
