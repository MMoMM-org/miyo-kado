test/MiYo-Kado/.obsidian/plugins/miyo-kado/styles.css
test/MiYo-Kado/.obsidian/plugins/miyo-kado/audit.log
test/MiYo-Kado/logs/

# Exclude macOS Finder (System Explorer) View States
.DS_Store

# Workspace scratch / inter-project message channels (not tracked)
temp/
_inbox/
_outbox/

# MCP config (contains API keys)
.mcp.json

